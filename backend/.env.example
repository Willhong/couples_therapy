# =============================================================================
# CouplesAI Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Django Core
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=          # Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
ALLOWED_HOSTS=localhost,yourdomain.com

# NOTE: SIMPLE_JWT SIGNING_KEY inherits from DJANGO_SECRET_KEY.
# Changing SECRET_KEY invalidates all existing JWT tokens.
# To rotate independently, add JWT_SIGNING_KEY and update base.py.

# Database
DATABASE_URL=postgres://user:pass@db:5432/couplesai

# Redis (db 0: Channels, db 1: Celery, db 2: Cache)
REDIS_URL=redis://redis:6379/0
CACHE_REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# LLM
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=google/gemini-3-flash-preview
OPENROUTER_SUMMARY_MODEL=google/gemini-3-flash-preview

# Transcription
OPENAI_API_KEY=

# Encryption
FERNET_KEYS=              # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Celery
CELERY_TASK_ALWAYS_EAGER=false

# Sentry (optional)
SENTRY_DSN=
